  "bin": {
    "agent-wallet": "./cli.js"
  },
  "exports": {
    ".": "./src/index.js",
    "./sdk": "./sdk.js",
    "./cli": "./cli.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
