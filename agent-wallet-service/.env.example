# Server
PORT=3000
NODE_ENV=development  # or 'production'

# ===========================================
# SECURITY (Required in Production)
# ===========================================
WALLET_ENCRYPTION_KEY=your-32-byte-hex-key-here  # Required in production (32 bytes = 64 hex chars)
WALLET_ENCRYPTION_SALT=unique-salt-string-here   # Optional: custom salt for key derivation
API_KEY_HASH_SECRET=your-hmac-secret-for-api-keys  # Required for DB-backed auth in production
SHOW_BOOTSTRAP_SECRET=false  # Set to 'true' only during initial setup to see the bootstrap key

# ===========================================
# STORAGE BACKEND
# ===========================================
# Options: 'json' (default) or 'db' (PostgreSQL)
STORAGE_BACKEND=json
AUTH_BACKEND=json  # Options: 'json' or 'db'

# PostgreSQL (when using DB storage)
DATABASE_URL=postgresql://user:password@localhost:5432/agentwallet

# ===========================================
# RATE LIMITING
# ===========================================
# Strategy: 'memory' for local single-instance dev, 'redis' for distributed/prod
RATE_LIMIT_STRATEGY=memory
REDIS_URL=redis://localhost:6379

# ===========================================
# COINBASE CDP (Optional - viem used by default)
# ===========================================
CDP_API_KEY_NAME=your-key-name
CDP_API_KEY_PRIVATE_KEY=your-private-key

# ===========================================
# MANAGED RPC (Recommended)
# ===========================================
# Single Alchemy key used across EVM chains in viem-wallet.js
ALCHEMY_API_KEY=your-alchemy-api-key

# Optional: comma-separated override / priority list for Base Sepolia
# Example: https://base-sepolia.g.alchemy.com/v2/<key>,https://base-sepolia-public.nodies.app
BASE_SEPOLIA_RPCS=

# ===========================================
# RPC URLs - TESTNETS (Sepolia)
# ===========================================
BASE_SEPOLIA_RPC=https://sepolia.base.org  # Legacy single RPC setting (kept for compatibility)
ETHEREUM_SEPOLIA_RPC=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
POLYGON_AMOY_RPC=https://rpc-amoy.polygon.technology
ARBITRUM_SEPOLIA_RPC=https://sepolia.arbitrum.io/rpc

# ===========================================
# RPC URLs - MAINNETS
# ===========================================
ETHEREUM_RPC=https://eth.llamarpc.com
BASE_RPC=https://mainnet.base.org
POLYGON_RPC=https://polygon-rpc.com
ARBITRUM_RPC=https://arb1.arbitrum.io/rpc
OPTIMISM_RPC=https://mainnet.optimism.io

# Free-tier BYO RPC safety controls
BYO_RPC_ALLOWED_HOSTS=*.g.alchemy.com,*.alchemy.com
ALLOW_INSECURE_BYO_RPC=false

# ===========================================
# FEE COLLECTION
# ===========================================
TREASURY_ADDRESS=0x...  # Where fees go (leave empty to disable)
FEE_BASIS_POINTS=50     # 50 = 0.5% fee

# ===========================================
# WEBHOOKS (Optional)
# ===========================================
WEBHOOK_SECRET=your-webhook-secret-here

# ===========================================
# OPTIONAL API KEY (for protected endpoints)
# ===========================================
API_KEY=your-api-key

# ===========================================
# X402 PAYMENT CHAINING (Optional)
# ===========================================
# Enable X402 payment for API endpoints
X402_ENABLED=false
X402_PAYMENT_RECIPIENT=0x...  # Wallet address to receive payments

# Payment rates (in wei)
X402_RATE_DEFAULT=1000000000000000    # 0.001 ETH per request
X402_RATE_WALLET_CREATE=1000000000000000  # 0.001 ETH
X402_RATE_WALLET_SEND=2000000000000000    # 0.002 ETH
X402_RATE_IDENTITY_CREATE=5000000000000000  # 0.005 ETH
X402_RATE_DEFI=3000000000000000          # 0.003 ETH

# ===========================================
# ERC-4337 GASLESS TRANSACTIONS (Optional)
# ===========================================
# Enable gasless transactions via account abstraction
ERC4337_ENABLED=false
ERC4337_ENTRY_POINT=0x5FF137D4b0FDCD49DcA30c7CF57E578a026d2789
ERC4337_PAYMASTER_ADDRESS=0x...  # Your deployed paymaster contract

# Token payment for gas (optional)
ERC4337_TOKEN_PAYMENT_ADDRESS=0x...  # ERC20 token contract for gas payment
ERC4337_EXCHANGE_ADDRESS=0x...  # DEX for token -> native swap

# ===========================================
# AGENT ECONOMY (Universal - NO DISCRIMINATION!)
# ===========================================
# Enable agent-to-agent payments (ANY agent can pay ANY agent!)
AGENT_ECONOMY_ENABLED=true

# Platform fee (basis points) - 25 = 0.25%
ECONOMY_FEE_BPS=25

# Treasury address for economy fees
ECONOMY_TREASURY=0x...  # Your treasury address

# Minimum payment amount in wei
ECONOMY_MIN_PAYMENT=1000000000000

# ===========================================
# IPFS METADATA STORAGE (Optional)
# ===========================================
# Enable IPFS storage for metadata
IPFS_ENABLED=false

# IPFS provider: pinata, infura, web3storage, local
IPFS_PROVIDER=pinata

# Pinata credentials
IPFS_API_KEY=your-pinata-api-key
IPFS_API_SECRET=your-pinata-api-secret

# Infura credentials (alternative)
IPFS_PROJECT_ID=your-infura-project-id
IPFS_PROJECT_SECRET=your-infura-project-secret

# IPFS gateway (public gateway for reading)
IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/

# Local IPFS node (if using local provider)
IPFS_LOCAL_NODE=http://localhost:5001
